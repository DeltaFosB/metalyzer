%{
#include <iostream>
#include <string>
#include <sstream>

enum class CalcToken {
    TOK_EOF = -1,
    TOK_ERROR = -2,
    NUM_INT = 1,
    KW_PLUS = 2,
    KW_MINUS = 3,
    KW_MUL = 4,
    KW_DIV = 5,
    KW_ASSIGN = 6,
    TOK_ID = 7
};
%}

%%

[0-9]+    { return (int)CalcToken::NUM_INT; }
plus      { return (int)CalcToken::KW_PLUS; }
minus     { return (int)CalcToken::KW_MINUS; }
mul       { return (int)CalcToken::KW_MUL; }
div       { return (int)CalcToken::KW_DIV; }
assign    { return (int)CalcToken::KW_ASSIGN; }
[a-z]+    { return (int)CalcToken::TOK_ID; }

%%

int main() {
    using namespace user_code;

    std::cout << "=== Testing Alphanumeric Calculator Lexer ===\n";
    std::string input = "x assign 10 plus 25 mul a";
    std::stringstream stream(input);

    MyLexer lexer(stream);
    std::string lexeme;
    int tok;

    while (lexer.hasMore()) {
        tok = lexer.nextToken(lexeme);
        std::cout << "Token ID: " << tok 
                  << " | Lexeme: [" << lexeme 
                  << "] | Location: L" << lexer.getLine() 
                  << " C" << lexer.getCol() << "\n";
        
        if (tok == -1 || tok == -2) break;
    }
    return 0;
}
