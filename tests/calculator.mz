%{
#include <iostream>
#include <string>
#include <sstream>

enum class CalcToken {
    TOK_EOF = -1,
    TOK_ERROR = -2,
    NUM_INT = 1,
    PLUS = 2,
    MINUS = 3,
    MUL = 4,
    DIV = 5,
    ASSIGN = 6,
    ADD_ASSIGN = 7,
    LPAREN = 8,
    RPAREN = 9,
    TOK_ID = 10 // Added to support variable tracking
};
%}

%%

[0-9]+    { return (int)CalcToken::NUM_INT; }
[a-z]+    { return (int)CalcToken::TOK_ID; } // Fix: Added an identifier rule to consume 'x'
\+=       { return (int)CalcToken::ADD_ASSIGN; }
=         { return (int)CalcToken::ASSIGN; }
\+        { return (int)CalcToken::PLUS; }
-         { return (int)CalcToken::MINUS; }
\* { return (int)CalcToken::MUL; }
/         { return (int)CalcToken::DIV; }
\(        { return (int)CalcToken::LPAREN; }
\)        { return (int)CalcToken::RPAREN; }

%%

int main() {
    using namespace user_code;

    std::cout << "--- Testing Calculator Lexer ---\n";
    std::string input = "x = 10 + 25 * (4 - 2) += 5";
    std::stringstream stream(input);

    MyLexer lexer(stream);
    std::string lexeme;
    int tok;

    while (lexer.hasMore()) {
        tok = lexer.nextToken(lexeme);
        std::cout << "Token ID: " << tok 
                  << " | Lexeme: [" << lexeme 
                  << "] | Location: L" << lexer.getLine() 
                  << " C" << lexer.getCol() << "\n";
        
        if (tok == -1) {
            std::cout << "Reached EOF cleanly.\n";
            break;
        }
        if (tok == -2) {
            std::cout << "Lexical error encountered!\n";
            break;
        }
    }
    return 0;
}
