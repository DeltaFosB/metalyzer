%{
#include <iostream>
#include <string>
#include <sstream>

enum class Token {
    TOK_EOF = -1,
    TOK_ERROR = -2,
    KEYWORD = 1,
    IDENTIFIER = 2,
    NUMBER = 3,
    ASSIGN = 4,
    SEMICOLON = 5
};
%}

%%

let       { return (int)Token::KEYWORD; }
[a-z]+    { return (int)Token::IDENTIFIER; }
[0-9]+    { return (int)Token::NUMBER; }
=         { return (int)Token::ASSIGN; }
;         { return (int)Token::SEMICOLON; }

%%

int main() {
    using namespace user_code;

    std::cout << "=== Verifying Precision Tab Tracking ===\n";
    
    // Constructing a string with intentional tab and space layouts:
    // Line 1: "let a = 10;" (Using mixed spaces and tabs)
    //         'let' starts at C1, length 3 -> ends at C4.
    //         Then a '\t' character. It should snap from C4 to C5.
    //         'a' should sit exactly at Column 5.
    // Line 2: "\t\tlet b = 20;" (Double tabs at the start of the line)
    //         First tab snaps C1 -> C5. Second tab snaps C5 -> C9.
    //         'let' should begin exactly at Column 9.
    
    std::string input = "let\ta = 10;\n\t\tlet b = 20;";
    std::stringstream stream(input);

    MyLexer lexer(stream);
    std::string lexeme;
    int tok;

    while (lexer.hasMore()) {
        tok = lexer.nextToken(lexeme);
        if (tok == -1) break;
        
        std::cout << "Token: " << tok 
                  << " | Lexeme: [" << lexeme 
                  << "] | Location: Line " << lexer.getLine() 
                  << ", Column " << lexer.getCol() << "\n";
                  
        if (tok == -2) break;
    }
    return 0;
}
