%{
#include <iostream>
#include <string>
#include <sstream>

enum class JsonToken {
    TOK_EOF = -1,
    TOK_ERROR = -2,
    OBJ_START = 1,
    OBJ_END = 2,
    ARR_START = 3,
    ARR_END = 4,
    COLON = 5,
    COMMA = 6,
    KW_TRUE = 7,
    KW_FALSE = 8,
    KW_NULL = 9,
    STRING_LIT = 10
};
%}

%%

\{         { return (int)JsonToken::OBJ_START; }
\}         { return (int)JsonToken::OBJ_END; }
\[         { return (int)JsonToken::ARR_START; }
\]         { return (int)JsonToken::ARR_END; }
:          { return (int)JsonToken::COLON; }
,          { return (int)JsonToken::COMMA; }
true       { return (int)JsonToken::KW_TRUE; }
false      { return (int)JsonToken::KW_FALSE; }
null       { return (int)JsonToken::KW_NULL; }

/* Expanded string rule: captures printable ASCII, spaces, and escaped sequences like \\ or \" */
\"([a-zA-Z0-9[:space:]!#-\[\]-~]|\\[\"\\/bfnrt])*\" { return (int)JsonToken::STRING_LIT; }

%%

int main() {
    using namespace user_code;

    // Instantiate with telemetry explicitly deactivated to isolate throughput speed
    MyLexer lexer(std::cin, false);
    std::string lexeme;
    
    while (lexer.hasMore()) {
        int tok = lexer.nextToken(lexeme);
        
        if (tok == (int)JsonToken::TOK_EOF) {
            break;
        }
        
        if (tok == (int)JsonToken::TOK_ERROR) {
            // Log the error coordinate metrics but continue scanning to pull the full payload through
            std::cout << "Lexical Error | Lexeme: " << lexeme 
                      << " | Line: " << lexer.getLine() 
                      << " | Col: " << lexer.getCol() << "\n";
            continue;
        }
        
        // Emit pristine, pipe-delimited data metrics matching the snapshot criteria
        std::cout << tok << " | " << lexeme << " | " << lexer.getLine() << " | " << lexer.getCol() << "\n";
    }
    return 0;
}
