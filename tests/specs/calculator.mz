%{
#include <iostream>
#include <string>
#include <sstream>
#include <iomanip>

enum class CalcToken {
    TOK_EOF = -1,
    TOK_ERROR = -2,
    NUM_INT = 1,
    PLUS = 2,
    MINUS = 3,
    MUL = 4,
    DIV = 5,
    ASSIGN = 6,
    ADD_ASSIGN = 7,
    LPAREN = 8,
    RPAREN = 9,
    TOK_ID = 10
};
%}

%%

[0-9]+    { return (int)CalcToken::NUM_INT; }
[a-z]+    { return (int)CalcToken::TOK_ID; }
\+=       { return (int)CalcToken::ADD_ASSIGN; }
=         { return (int)CalcToken::ASSIGN; }
\+        { return (int)CalcToken::PLUS; }
-         { return (int)CalcToken::MINUS; }
\* { return (int)CalcToken::MUL; }
/         { return (int)CalcToken::DIV; }
\(        { return (int)CalcToken::LPAREN; }
\)        { return (int)CalcToken::RPAREN; }
\   { }
\t { }
\n { }
\r { }

%%

int main() {
    using namespace user_code;

    // 1. Pass the standard input stream directly into the chunk-swapping engine.
    // This restores live, interactive terminal capability with zero per-character vtable overhead.
    MyLexer lexer(std::cin, false);
    std::string lexeme;
    
    // 2. Loop continuously based on whether the internal memory window can refresh itself from the stream
    while (lexer.hasMore()) {
        int tok = lexer.nextToken(lexeme);
        
        // 3. Match against the template core return codes mapped to enum boundaries
        if (tok == -1 || tok == static_cast<int>(CalcToken::TOK_EOF)) {
            break; // Clean exit on true stream termination
        }
        
        if (tok == -2 || tok == static_cast<int>(CalcToken::TOK_ERROR)) {
            std::cout << "Lexical Error | Lexeme: " << lexeme 
                      << " | Line: " << lexer.getLine() 
                      << " | Col: " << lexer.getCol() << "\n";
            continue; // Keep streaming tokens without crashing or locking the interface
        }
        
        std::cout << tok << " | " << lexeme << " | " << lexer.getLine() << " | " << lexer.getCol() << "\n";
    }
    
    return 0;
}
