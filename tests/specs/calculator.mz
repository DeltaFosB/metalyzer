%{
#include <iostream>
#include <string>
#include <sstream>

enum class CalcToken {
    TOK_EOF = -1,
    TOK_ERROR = -2,
    NUM_INT = 1,
    PLUS = 2,
    MINUS = 3,
    MUL = 4,
    DIV = 5,
    ASSIGN = 6,
    ADD_ASSIGN = 7,
    LPAREN = 8,
    RPAREN = 9,
    TOK_ID = 10 // Added to support variable tracking
};
%}

%%

[0-9]+    { return (int)CalcToken::NUM_INT; }
[a-z]+    { return (int)CalcToken::TOK_ID; } // Fix: Added an identifier rule to consume 'x'
\+=       { return (int)CalcToken::ADD_ASSIGN; }
=         { return (int)CalcToken::ASSIGN; }
\+        { return (int)CalcToken::PLUS; }
-         { return (int)CalcToken::MINUS; }
\* { return (int)CalcToken::MUL; }
/         { return (int)CalcToken::DIV; }
\(        { return (int)CalcToken::LPAREN; }
\)        { return (int)CalcToken::RPAREN; }

%%

int main() {
    using namespace user_code;

    // Point the lexer directly to standard input for dynamic runtime piping
    MyLexer lexer(std::cin);
    std::string lexeme;
    int tok;

    while (lexer.hasMore()) {
        tok = lexer.nextToken(lexeme);
        
        // Emit airtight, pipe-delimited data metrics for the snapshot validation matrix
        std::cout << tok << " | " << lexeme << " | " << lexer.getLine() << " | " << lexer.getCol() << "\n";
        
        if (tok == -1) {
            break;
        }
        if (tok == -2) {
            break;
        }
    }
    return 0;
}
