%{
#include <iostream>
#include <string>
#include <sstream>
#include <iomanip>

enum class CalcToken {
    TOK_EOF = -1,
    TOK_ERROR = -2,
    NUM_INT = 1,
    PLUS = 2,
    MINUS = 3,
    MUL = 4,
    DIV = 5,
    ASSIGN = 6,
    ADD_ASSIGN = 7,
    LPAREN = 8,
    RPAREN = 9,
    TOK_ID = 10
};
%}

%%

[0-9]+    { return (int)CalcToken::NUM_INT; }
[a-z]+    { return (int)CalcToken::TOK_ID; }
\+=       { return (int)CalcToken::ADD_ASSIGN; }
=         { return (int)CalcToken::ASSIGN; }
\+        { return (int)CalcToken::PLUS; }
-         { return (int)CalcToken::MINUS; }
\* { return (int)CalcToken::MUL; }
/         { return (int)CalcToken::DIV; }
\(        { return (int)CalcToken::LPAREN; }
\)        { return (int)CalcToken::RPAREN; }

%%

int main() {
    using namespace user_code;

    // Explicitly activate runtime observability tracking via our secondary constructor flag
    MyLexer lexer(std::cin, true);
    std::string lexeme;
    
    // Print a structured, readable matrix header block
    std::cout << "\n[LEXICAL BOUNDARY SNAPSHOT MATRIX]\n";
    std::cout << "=========================================\n";
    std::cout << " TOKEN ID | LEXEME     | LINE | COLUMN   \n";
    std::cout << "-----------------------------------------\n";

    while (lexer.hasMore()) {
        int tok = lexer.nextToken(lexeme);
        
        // Trap stream boundaries cleanly
        if (tok == (int)CalcToken::TOK_EOF) {
            break;
        }
        if (tok == (int)CalcToken::TOK_ERROR) {
            std::cout << "  [ERROR] | INVALID    | " << lexer.getLine() << "    | " << lexer.getCol() << "\n";
            break;
        }

        // Emit an aligned, readable matrix formatting pass instead of loose pipes
        std::cout << " " 
                  << std::left  << std::setw(8) << tok      << " | "
                  << std::left  << std::setw(10) << lexeme   << " | "
                  << std::left  << std::setw(4) << lexer.getLine() << " | "
                  << std::left  << lexer.getCol()  << "\n";
    }
    
    std::cout << "=========================================\n";
    
    // As main() returns, lexer's destructor fires here, appending the automated telemetry summary block
    return 0;
}
